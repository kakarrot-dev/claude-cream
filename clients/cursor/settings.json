{
  // ============================================================
  // 主题 / 窗口 / 工作台
  // ============================================================

  "workbench.colorTheme": "GitHub Light",
  "workbench.iconTheme": "material-icon-theme",

  "workbench.startupEditor": "none",
  "workbench.settings.editor": "json",
  "workbench.editor.enablePreview": false,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.labelFormat": "short",
  "workbench.editor.showIcons": true,
  "workbench.editor.wrapTabs": false,
  "workbench.editor.limit.enabled": false,

  "workbench.sideBar.location": "left",
  "workbench.activityBar.location": "default",
  "workbench.tree.indent": 18,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.list.smoothScrolling": true,
  "workbench.reduceMotion": "off",

  "window.commandCenter": false,
  "window.titleBarStyle": "native",
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",
  "window.restoreWindows": "all",
  "window.newWindowDimensions": "inherit",
  "window.zoomLevel": 0,
  "window.nativeTabs": false,
  "window.dialogStyle": "custom",

  // ============================================================
  // GitHub Light 轻量微调
  // 不强改背景，只增强边界、选区、缩进线
  // ============================================================

  "workbench.colorCustomizations": {
    "editorLineNumber.foreground": "#8c959f",
    "editorLineNumber.activeForeground": "#24292f",

    "editorIndentGuide.background1": "#d0d7de",
    "editorIndentGuide.activeBackground1": "#57606a",

    "editor.lineHighlightBackground": "#f6f8fa",
    "editor.selectionBackground": "#bfd7ff",

    "sideBar.border": "#d0d7de",
    "panel.border": "#d0d7de",
    "editorGroup.border": "#d0d7de",

    "tab.border": "#d0d7de",
    "tab.activeBorderTop": "#0969da",
    "tab.unfocusedActiveBorderTop": "#8c959f",
  },

  // ============================================================
  // 编辑器字体 / 阅读体验
  // ============================================================

  "editor.fontFamily": "JetBrainsMono Nerd Font, JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 23,
  "editor.fontLigatures": true,
  "editor.fontWeight": "400",
  "editor.letterSpacing": 0.1,

  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,

  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 100,

  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 6,
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,

  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorWidth": 2,

  "editor.lineNumbers": "on",
  "editor.renderLineHighlight": "line",
  "editor.renderWhitespace": "selection",
  "editor.renderControlCharacters": false,

  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,

  "editor.unicodeHighlight.invisibleCharacters": true,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.nonBasicASCII": false,

  // ============================================================
  // 补全 / 提示 / 跳转
  // ============================================================

  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on",
  },
  "editor.suggestSelection": "first",
  "editor.suggest.preview": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.snippetSuggestions": "top",
  "editor.tabCompletion": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.acceptSuggestionOnCommitCharacter": false,

  "editor.parameterHints.enabled": true,
  "editor.hover.delay": 300,
  "editor.links": true,
  "editor.linkedEditing": true,
  "editor.rename.enablePreview": true,

  "editor.gotoLocation.multipleDefinitions": "peek",
  "editor.gotoLocation.multipleReferences": "peek",
  "editor.gotoLocation.multipleImplementations": "peek",

  "editor.codeLens": true,
  "editor.lightbulb.enabled": "on",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.accessibilitySupport": "off",

  // ============================================================
  // 保存 / 格式化 / 自动修复
  // ============================================================

  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1200,
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.formatOnSaveMode": "file",
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.addMissingImports": "explicit",
    "source.organizeImports": "never",
  },

  // ============================================================
  // Prettier
  // ============================================================

  "prettier.useEditorConfig": true,
  "prettier.printWidth": 100,
  "prettier.tabWidth": 2,
  "prettier.semi": true,
  "prettier.singleQuote": false,
  "prettier.trailingComma": "es5",
  "prettier.bracketSpacing": true,
  "prettier.arrowParens": "always",
  "prettier.endOfLine": "lf",

  // ============================================================
  // ESLint
  // ============================================================

  "eslint.enable": true,
  "eslint.alwaysShowStatus": true,
  "eslint.format.enable": false,
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "mode": "auto",
    },
  ],
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "astro"],

  // ============================================================
  // Tailwind / CSS / UI
  // ============================================================

  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript",
    "javascript": "javascript",
    "javascriptreact": "javascript",
    "astro": "html",
    "mdx": "html",
  },
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "class:list",
    "ngClass",
    ".*Class",
    ".*ClassName",
  ],
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["tv\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
  ],
  "tailwindCSS.lint.cssConflict": "warning",
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.invalidConfigPath": "error",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidTailwindDirective": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.recommendedVariantOrder": "warning",

  "css.validate": true,
  "less.validate": true,
  "scss.validate": true,
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",

  "html.autoClosingTags": true,
  "html.format.wrapLineLength": 100,
  "html.format.indentInnerHtml": true,

  "emmet.triggerExpansionOnTab": true,
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "astro": "html",
    "mdx": "html",
  },

  // ============================================================
  // 文件关联
  // ============================================================

  "files.associations": {
    "*.mdc": "markdown",
    "*.mdx": "mdx",
    "*.css": "tailwindcss",
    ".env*": "dotenv",
    "components.json": "jsonc",
    "tsconfig*.json": "jsonc",
    "eslint.config.*": "javascript",
    "prettier.config.*": "javascript",
    "tailwind.config.*": "typescript",
    "postcss.config.*": "javascript",
    "AGENTS.md": "markdown",
    "CLAUDE.md": "markdown",
    "DESIGN.md": "markdown",
  },

  // ============================================================
  // 各语言格式化
  // ============================================================

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode",
    "editor.formatOnSave": true,
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off",
    },
    "editor.trimAutoWhitespace": false,
    "files.trimTrailingWhitespace": false,
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "files.trimTrailingWhitespace": false,
  },

  // ============================================================
  // Markdown / 产品文档
  // ============================================================

  "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', sans-serif",
  "markdown.preview.fontSize": 16,
  "markdown.preview.lineHeight": 1.8,
  "markdown.preview.breaks": false,
  "markdown.preview.scrollPreviewWithEditor": true,
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.validate.enabled": true,
  "markdown.updateLinksOnFileMove.enabled": "always",

  "markdown.extension.toc.levels": "2..4",
  "markdown.extension.orderedList.marker": "one",
  "markdown.extension.preview.autoShowPreviewToSide": false,

  // ============================================================
  // Explorer 文件树
  // ============================================================

  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.incrementalNaming": "smart",
  "explorer.sortOrder": "type",
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": true,

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, package-lock.json, yarn.lock, bun.lock, bun.lockb, .npmrc, .node-version, .nvmrc",
    "tsconfig.json": "tsconfig.*.json",
    "vite.config.*": "vitest.config.*, playwright.config.*, cypress.config.*, playwright.config.*",
    "next.config.*": "middleware.ts, instrumentation.ts, instrumentation-client.ts",
    "tailwind.config.*": "postcss.config.*, components.json",
    "eslint.config.*": "prettier.config.*, .prettierrc, .prettierignore",
    "README.md": "AGENTS.md, CLAUDE.md, DESIGN.md, CHANGELOG.md",
    ".env": ".env.*, .env.example",
  },

  // ============================================================
  // 搜索 / 文件排除 / 性能
  // ============================================================

  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.smartCase": true,
  "search.followSymlinks": false,
  "search.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/.astro": true,
    "**/.vercel": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/.cache": true,
    "**/pnpm-lock.yaml": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
  },

  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/.astro": false,
    "**/.vercel": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
  },

  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/.nuxt/**": true,
    "**/.astro/**": true,
    "**/.vercel/**": true,
    "**/.turbo/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
  },

  // ============================================================
  // Git
  // ============================================================

  "git.enabled": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.branchProtection": ["main", "master", "prod", "production"],
  "git.branchProtectionPrompt": "alwaysCommitToNewBranch",
  "git.openRepositoryInParentFolders": "always",
  "git.inputValidation": true,
  "git.inputValidationLength": 72,
  "git.inputValidationSubjectLength": 72,
  "git.ignoreRebaseWarning": true,
  "git.ignoreLimitWarning": true,
  "git.decorations.enabled": true,

  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.statusBar.enabled": false,
  "gitlens.views.repositories.files.layout": "tree",

  // ============================================================
  // Diff / Merge
  // ============================================================

  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "diffEditor.wordWrap": "on",
  "diffEditor.codeLens": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "mergeEditor.enabled": true,

  // ============================================================
  // 终端：macOS + Ghostty
  // Cursor 内置终端用 zsh
  // 外部终端交给 Ghostty
  // ============================================================

  "terminal.external.osxExec": "Ghostty.app",

  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "/bin/zsh",
      "args": ["-l"],
    },
  },

  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font, JetBrains Mono, Menlo, Monaco, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.25,
  "terminal.integrated.letterSpacing": 0,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.scrollback": 20000,
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.hideCondition": "singleTerminal",
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.persistentSessionScrollback": 5000,
  "terminal.integrated.localEchoEnabled": "auto",
  "terminal.integrated.gpuAcceleration": "auto",
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.confirmOnExit": "never",
  "terminal.integrated.confirmOnKill": "editor",

  // ============================================================
  // 任务 / 调试
  // ============================================================

  "task.autoDetect": "on",
  "task.problemMatchers.neverPrompt": true,

  "debug.console.fontFamily": "JetBrainsMono Nerd Font, JetBrains Mono, Menlo, Monaco, monospace",
  "debug.console.fontSize": 14,
  "debug.console.lineHeight": 23,
  "debug.internalConsoleOptions": "neverOpen",
  "debug.toolBarLocation": "docked",
  "debug.showBreakpointsInOverviewRuler": true,

  // ============================================================
  // 错误提示：Error Lens
  // ============================================================

  "problems.decorations.enabled": true,

  "errorLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.gutterIconsEnabled": false,
  "errorLens.statusBarMessageEnabled": true,
  "errorLens.messageMaxChars": 180,
  "errorLens.delay": 300,
  "errorLens.fontStyleItalic": false,
  "errorLens.followCursor": "closestProblem",

  // ============================================================
  // 拼写检查：Code Spell Checker
  // ============================================================

  "cSpell.language": "en,zh-CN",
  "cSpell.enabledLanguageIds": [
    "markdown",
    "mdx",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "yaml",
  ],
  "cSpell.userWords": [
    "AGENTS",
    "CLAUDE",
    "DESIGN",
    "Astro",
    "Cursor",
    "Ghostty",
    "JetBrainsMono",
    "Kakarrot",
    "Lucide",
    "Monaco",
    "Radix",
    "React",
    "TypeScript",
    "shadcn",
    "tailwindcss",
    "clsx",
    "cva",
    "lucide",
    "radix",
    "zustand",
    "sonner",
    "cmdk",
    "frontmatter",
    "pnpm",
    "tsx",
    "jsx",
  ],

  // ============================================================
  // 包管理 / Node 项目
  // ============================================================

  "npm.enableRunFromFolder": true,
  "npm.packageManager": "pnpm",

  // ============================================================
  // 安全 / 遥测 / 扩展
  // ============================================================

  "security.workspace.trust.enabled": true,
  "security.workspace.trust.startupPrompt": "once",

  "telemetry.telemetryLevel": "off",

  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "extensions.ignoreRecommendations": true,
}
