# ============================================================
#  Claude Cream Light — Ghostty Theme
#  暖米黄画布 + 珊瑚橙强调 + 深墨文字
#  基于 Claude.com 官方视觉 token（DESIGN-claude.md）
# ============================================================

# 主体背景 & 前景
background = faf9f5
foreground = 3d3d3a

# 光标（珊瑚橙）
cursor-color = cc785c
cursor-text  = faf9f5

# 选中区（淡珊瑚 + 深墨文字）
selection-background = fce5d0
selection-foreground = 141413

# ── ANSI 16 色 ────────────────────────────────────────────────
# 0-7 标准色，8-15 亮色变体
# 设计原则：Claude token 优先（primary/accent-teal/accent-amber/success/warning/error）
# 未定义的槽位用调色板衍生色补齐

# 0  Black / 深墨
palette = 0=141413
# 1  Red / 错误红
palette = 1=c64545
# 2  Green / 成功绿
palette = 2=5db872
# 3  Yellow / 警告琥珀
palette = 3=d4a017
# 4  Blue（Claude 无蓝调；用青绿 accent-teal 兜底，避免出现冷色调破坏氛围）
palette = 4=5db8a6
# 5  Magenta / 珊瑚主色
palette = 5=cc785c
# 6  Cyan / 青绿 accent-teal
palette = 6=7fbfa8
# 7  White / 弱正文米色
palette = 7=6c6a64

# 8  Bright Black / 暖灰
palette = 8=8e8b82
# 9  Bright Red / 提亮红
palette = 9=e06565
# 10 Bright Green
palette = 10=7fd490
# 11 Bright Yellow / 琥珀 accent-amber
palette = 11=e8a55a
# 12 Bright Blue
palette = 12=7fd4c2
# 13 Bright Magenta / 提亮珊瑚
palette = 13=e08b6f
# 14 Bright Cyan
palette = 14=9fd4c2
# 15 Bright White / 深墨强调
palette = 15=141413
